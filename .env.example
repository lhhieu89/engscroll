# EngScroll environment configuration.
# Copy to `.env.local` and fill in. All values are OPTIONAL — the app runs
# fully (anonymous + email auth + feed) with none of them set.

# --- Google login (OAuth 2.0) ----------------------------------------------
# Get these from https://console.cloud.google.com → APIs & Services →
# Credentials → OAuth client ID (type: Web application).
# Authorized redirect URI must be: <your-origin>/api/auth/google/callback
# When BOTH are set, the "Continue with Google" button appears automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the callback URL (defaults to <request-origin>/api/auth/google/callback)
# GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# --- Admin content pipeline ------------------------------------------------
# If set, /admin and /api/admin/* require header `x-admin-key: <value>`
# (or ?key=<value>). If unset, admin tools are open (fine for local/soft-launch).
ADMIN_KEY=

# --- Database (Postgres via Drizzle) ---------------------------------------
DATABASE_URL=postgres://lehonghieu@localhost:5432/endscroll

# --- SEO / canonical site origin -------------------------------------------
# Public origin used for canonical URLs, sitemap, OG images and share links.
# No trailing slash. Defaults to https://engscroll.com when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
