# ── EngScroll PRODUCTION environment ──────────────────────────────────────
# On the server: cp .env.production.example .env  (at /var/www/engscroll/.env)
# then fill in real values. docker-compose.prod.yml reads this via env_file.

# --- App URL (NEXT_PUBLIC_* is inlined into the bundle at BUILD time) --------
# Changing this requires a Docker rebuild; the deploy workflow uses --no-cache.
NEXT_PUBLIC_SITE_URL=https://engscroll.com

# --- Port (must match nginx UPSTREAM_PORT and the healthcheck) ---------------
# Default 3016. Change here + re-run setup-nginx-ssl.sh with UPSTREAM_PORT to match.
APP_PORT=3016

# --- Database (host-installed PostgreSQL, NOT a container) -------------------
# The web/tools containers use host networking, so `localhost:5432` from the
# container is the host's PostgreSQL. Create the role + db once:
#   sudo -u postgres psql -c "CREATE USER engscroll WITH PASSWORD 'strong-pass';"
#   sudo -u postgres psql -c "CREATE DATABASE engscroll OWNER engscroll;"
# and ensure pg_hba.conf allows 127.0.0.1 with scram-sha-256/md5 (TCP, not peer).
DATABASE_URL=postgres://engscroll:strong-pass@localhost:5432/engscroll

# --- Admin content pipeline -------------------------------------------------
# If set, /admin and /api/admin/* require header `x-admin-key: <value>`
# (or ?key=<value>). Set a strong value in production.
ADMIN_KEY=change-me-long-random-secret

# --- Google login (OAuth 2.0) — optional ------------------------------------
# Authorized redirect URI must be: https://engscroll.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://engscroll.com/api/auth/google/callback
